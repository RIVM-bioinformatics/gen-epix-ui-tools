{
  "name": "@gen-epix/generate-api",
  "version": "0.1.1",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RIVM-bioinformatics/gen-epix-ui-tools.git",
    "directory": "packages/generate-api"
  },
  "author": "RIVM-bioinformatics <ids-bioinformatics@rivm.nl>",
  "homepage": "https://github.com/RIVM-bioinformatics/gen-epix",
  "type": "module",
  "files": [
    "bin"
  ],
  "main": "bin/generate-api.js",
  "scripts": {
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "check-types": "tsc --noemit",
    "build": "rimraf ./bin && rollup -c && chmod +x ./bin/generate-api.js",
    "generate-api": "vite-node --loader ts-node/esm ./src/generate-api.ts ../../../gen-epix-ui/src/api"
  },
  "bin": {
    "generate-api": "bin/generate-api.js"
  },
  "peerDependencies": {
    "@openapitools/openapi-generator-cli": "catalog:"
  },
  "dependencies": {
    "@gen-epix/tools-lib": "workspace:",
    "@openapitools/openapi-generator-cli": "catalog:",
    "formdata-polyfill": "4.0.10",
    "node-fetch": "3.3.2",
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "workspace:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-esbuild": "catalog:",
    "typescript": "catalog:",
    "vite-node": "catalog:"
  }
}
