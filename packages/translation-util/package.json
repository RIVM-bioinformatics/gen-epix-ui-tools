{
  "name": "@gen-epix/translation-util",
  "version": "0.0.5",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RIVM-bioinformatics/gen-epix-ui-tools.git",
    "directory": "packages/translation-util"
  },
  "author": "RIVM-bioinformatics <ids-bioinformatics@rivm.nl>",
  "homepage": "https://github.com/RIVM-bioinformatics/gen-epix",
  "type": "module",
  "files": [
    "bin"
  ],
  "main": "bin/translation-util.js",
  "scripts": {
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "check-types": "tsc --noemit",
    "translation-util": "vite-node --loader ts-node/esm ./src/translation-util.ts",
    "build": "rimraf ./bin && rollup -c && chmod +x ./bin/translation-util.js"
  },
  "bin": {
    "translation-util": "bin/translation-util.js"
  },
  "dependencies": {
    "@gen-epix/tools-lib": "*",
    "glob": "13.0.6",
    "chalk": "5.6.2",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "*",
    "@gen-epix/typescript-config": "*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "vite-node": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-esbuild": "catalog:"
  }
}